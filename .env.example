# App
TURNSTILE_SECRET=your_turnstile_secret
LOG_LEVEL=INFO
# Comma-separated allowed origins for browser calls
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Mail provider selection: mailjet or sendgrid
MAIL_PROVIDER=mailjet

# Common mail settings
TO_EMAIL=you@example.com
FROM_EMAIL=you@example.com

# Mailjet (required when MAIL_PROVIDER=mailjet)
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_API_SECRET=your_mailjet_api_secret

# SendGrid (required when MAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=your_sendgrid_api_key
